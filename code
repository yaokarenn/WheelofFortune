string convert2U(string p){
	for(int i=0; i < p.length(); i++){
		if(isalpha(p[i])) {
			p[i]='_';
		}
	}
	return p;
}

void display(string p){
	for(int i=0; i < p.length(); i++){
		cout << p[i] <<" ";
	}
	cout << endl;
}


